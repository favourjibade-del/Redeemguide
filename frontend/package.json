    "@mui/icons-material": "^5.14.0",
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "axios": "^1.6.0",
    "zustand": "^4.4.0",
    "leaflet": "^1.9.4",
    "react-leaflet": "^4.2.1",
    "@react-oauth/google": "^0.12.2",
